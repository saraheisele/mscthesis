@article{haalckCATERCombinedAnimal,
  title = {{{CATER}}: {{Combined Animal Tracking}} \& {{Environment Reconstruction}}},
  shorttitle = {{{CATER}}},
  author = {Haalck, Lars and Mangan, Michael and Wystrach, Antoine and Clement, Leo and Webb, Barbara and Risse, Benjamin},
  journaltitle = {Science Advances},
