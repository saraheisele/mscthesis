  issn = {0959-4388},
  doi = {10.1016/j.conb.2012.01.009},
  url = {https://www.sciencedirect.com/science/article/pii/S0959438812000116},
  urldate = {2024-04-23},
  abstract = {Neural codes often seem tailored to the type of information they must carry. Here we contrast the encoding strategies for two different communication signals in electric fish and describe the underlying cellular and network properties that implement them. We compare an aggressive signal that needs to be quickly detected, to a courtship signal whose quality needs to be evaluated. The aggressive signal is encoded by synchronized bursts and a predictive feedback input is crucial in separating background noise from the communication signal. The courtship signal is accurately encoded through a heterogenous population response allowing the discrimination of signal differences. Most importantly we show that the same strategies are used in other systems arguing that they evolved similar solutions because they faced similar tasks.},
  file = {/home/weygoldt/Zotero/storage/6PLVDBTM/Marsat et al. - 2012 - Cellular and circuit properties supporting different sensory coding strategies in electric fish and.pdf;/home/weygoldt/Zotero/storage/4I58WFAG/S0959438812000116.html}
}

@article{metznerCodingSignalsElectric1991,
  title = {The Coding of Signals in the Electric Communication of the Gymnotiform Fish {{Eigenmannia}}: {{From}} Electroreceptors to Neurons in the Torus Semicircularis of the Midbrain},
