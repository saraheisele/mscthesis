  title = {South {{American}} Electric Knifefishes of the Genus {{Archolaemus}} ({{Ostariophysi}}, {{Gymnotiformes}}): Undetected Diversity in a Clade of Rheophiles},
  shorttitle = {South {{American}} Electric Knifefishes of the Genus {{Archolaemus}} ({{Ostariophysi}}, {{Gymnotiformes}})},
  author = {VARI, RICHARD P. and DE SANTANA, CARLOS DAVID and WOSIACKI, WOLMAR B.},
  date = {2012-07-01},
  journaltitle = {Zoological Journal of the Linnean Society},
