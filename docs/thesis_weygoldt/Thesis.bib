@article{hazraSynSigGANGenerativeAdversarial2020,
  title = {{{SynSigGAN}}: {{Generative Adversarial Networks}} for {{Synthetic Biomedical Signal Generation}}},
  shorttitle = {{{SynSigGAN}}},
  author = {Hazra, Debapriya and Byun, Yung-Cheol},
  date = {2020-12},
  journaltitle = {Biology},
  volume = {9},
