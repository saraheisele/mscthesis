@article{hahnBiotelemetryRevealsMigratory2019,
  title = {Biotelemetry Reveals Migratory Behaviour of Large Catfish in the {{Xingu River}}, {{Eastern Amazon}}},
  author = {Hahn, Lisiane and Martins, Eduardo G. and Nunes, Leonardo D. and da Câmara, Luís Fernando and Machado, Leonardo S. and Garrone-Neto, Domingos},
